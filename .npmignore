# ── Version Control ──────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── Configuration (dev only) ─────────────────────────────────────────────
.eslintcache
.eslintrc.*
eslint.config.*
tsconfig.tsbuildinfo
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Documentation ────────────────────────────────────────────────────────
*.md
!README.md
LICENSE
CODE_OF_CONDUCT.md
CONTRIBUTING.md
CHANGELOG.md
docs/
HISTORY.md

# ── Development Files ─────────────────────────────────────────────────────
tests/
__tests__/
*.test.ts
*.spec.ts
*.test.tsx
*.spec.tsx
*.bench.ts
*.perf.ts
fixtures/
mocks/
stubs/
test-utils/

# ── Examples (bundled separately) ─────────────────────────────────────────
# Publish with: npm publish --include=examples
# Uncomment the line below if examples should NOT be published:
# examples/

# ── Build Artifacts (not needed in published package) ──────────────────────
dist/
build/
out/
*.tsbuildinfo
*.js.map
*.d.ts.map
coverage/
.nyc_output/

# ── CI / CD ───────────────────────────────────────────────────────────────
.github/
.gitlab-ci.yml
.circleci/
travis.yml
Jenkinsfile
.bitrise*

# ── Package internals ──────────────────────────────────────────────────────
scripts/
tools/
tasks/
dev/
scripts/get Attribute.ts
 Makefile
 Dockerfile
 docker-compose*
 bin/

# ── Node modules (already excluded by npm, but explicit for safety) ───────
node_modules/
.pnp
.pnp.js
.npm

# ── Logs & Temporary Files ─────────────────────────────────────────────────
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*
.pnpm-debug.log*
tmp/
temp/
.tmp/
*.tmp

# ── OS Files ──────────────────────────────────────────────────────────────
Thumbs.db
.DS_Store
desktop.ini
ehthumbs.db
Icon?
._*

# ── Misc ───────────────────────────────────────────────────────────────────
*.tgz
*.tar
*.zip
*.gz
*.rar
*.7z
*.exe
*.msi
*.dmg
*.pkg
*.deb
*.rpm
*.snap
*.flatpak
*.appimage
